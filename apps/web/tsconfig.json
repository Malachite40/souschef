{
    "extends": "@yeschefai/typescript-config/nextjs.json",
    "compilerOptions": {
        "baseUrl": ".",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "declaration": false,
        "declarationMap": false,
        "paths": {
            "@/*": ["./*"],
            "@yeschefai/ui/*": ["../../packages/ui/src/*"],
            "@yeschefai/db/*": ["../../packages/db/src/*"],
            "@yeschefai/db": ["../../packages/db/src/index.ts"],
            "@yeschefai/trpc/*": ["../../packages/trpc/src/*"],
            "@yeschefai/trpc/server": ["../../packages/trpc/src/server.ts"],
            "@yeschefai/trpc/client": ["../../packages/trpc/src/client.ts"]
        },
        "incremental": true
    },
    "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
    "exclude": ["node_modules", "capacitor.config.ts"]
}
